{
  "name": "@hps1978/tv-lrud-spatial",
  "version": "0.0.16",
  "description": "Spatial navigation library for react-native-web-tv (forked from @bbc/tv-lrud-spatial)",
  "main": "lib/lrud.min.js",
  "module": "lib/lrud.esm.js",
  "exports": {
    ".": {
      "types": "./lib/types.d.ts",
      "import": "./lib/lrud.esm.js",
      "require": "./lib/lrud.min.js",
      "default": "./lib/lrud.esm.js"
    }
  },
  "types": "lib/types.d.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "yarn test:core && yarn test:layouts",
    "test:layouts": "jest test/lrud.test.js",
    "test:core": "jest test/lrud-directional.test.js",
    "test:all": "jest test/lrud.test.js test/lrud-directional.test.js",
    "build": "rm -f lib/lrud.min.js lib/lrud.min.js.map lib/lrud.esm.js lib/lrud.esm.js.map && esbuild lib/lrud.js --bundle --format=cjs --platform=browser --minify --sourcemap --outfile=lib/lrud.min.js && esbuild lib/lrud.js --bundle --format=esm --platform=browser --minify --sourcemap --outfile=lib/lrud.esm.js",
    "server": "node ./test/server.js",
    "lint": "eslint .",
    "prepare": "husky install || exit 0",
    "preversion": "npm test",
    "postversion": "git push origin master --tags --no-verify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hps1978/tv-lrud-spatial.git"
  },
  "keywords": [],
  "author": "Harpreet Singh <hps1978@users.noreply.github.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/hps1978/tv-lrud-spatial/issues"
  },
  "homepage": "https://github.com/hps1978/tv-lrud-spatial#readme",
  "devDependencies": {
    "esbuild": "^0.25.10",
    "eslint": "^8.27.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-jest-formatting": "^3.1.0",
    "husky": "^8.0.0",
    "jest": "^29.4.3",
    "puppeteer": "^19.7.2"
  },
  "dependencies": {
    "@babel/cli": "^7.23.9",
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9"
  }
}
